# -------------------------------------------------------
# Copy this file to .env and fill in your own values.
# NEVER commit your actual .env file to Git.
# -------------------------------------------------------

# --- PostgreSQL ---
POSTGRES_DB=labelstudio
POSTGRES_USER=labelstudio
POSTGRES_PASSWORD=labelstudio

# --- Label Studio admin account (created on first boot) ---
LS_USERNAME=admin@gmail.com #Điền USERNAME và USERNAME phải khác với các annotators khác
LS_PASSWORD=Admin123! #Điền PASSWORD

# --- Port that Label Studio is exposed on the host ---
# Change this if 8080 is already in use on your machine
LS_PORT=8080

# --- API access (fill in after first login) ---
# Retrieve your API key from: http://localhost:8080/user/account
# Used by the helper scripts in scripts/
LS_URL=http://localhost:8080
LS_API_KEY=your_api_key_here #Điền API KEY sau khi đăng nhập để scripts có thể automate quá trình kiểm tra và xuất output

# --- Project ID (fill in after creating a project) ---
# Printed by scripts/create_project.py; also visible in the URL:
#   http://localhost:8080/projects/<PROJECT_ID>/
PROJECT_ID=
